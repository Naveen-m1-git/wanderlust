<% layout('layouts/boilerplate') -%>

<div class="container mt-4">

  <!-- Title -->
  <div class="row">
    <div class="col-md-6 mx-auto">
      <h3 class="mb-3"><%= listing.title %></h3>
    </div>
  </div>

  <!-- Listing Card -->
  <div class="row">
    <div class="col-md-6 mx-auto">
      <div class="card listing-card show-card">

        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing image">

        <div class="card-body">

          <p class="card-text">
            <i>Owned by: <%= listing.owner.username %></i>
          </p>

          <p class="card-text">
            <%= listing.description %>
          </p>

          <p class="card-text">
            <strong>Price:</strong> ₹ 
            <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
          </p>

          <p class="card-text">
            <strong>Location:</strong> <%= listing.location %>, <%= listing.country %>
          </p>

        </div>
      </div>
    </div>
  </div>

  <!-- Edit Delete Buttons -->
  <% if(currUser && listing.owner.equals(currUser._id)) { %>
  <div class="row mt-3">
    <div class="col-md-6 mx-auto d-flex justify-content-between">

      <a href="/listings/<%= listing._id %>/edit" 
         class="btn btn-dark">
         Edit
      </a>

      <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-danger">Delete</button>
      </form>

    </div>
  </div>
  <% } %>

  <hr class="my-4">

  <!-- Review Form -->
  <div class="row">
    <div class="col-md-6 mx-auto">

      <% if (currUser) { %>

      <h4 class="mb-3">Leave a Review</h4>

      <form action="/listings/<%= listing._id %>/reviews" 
            method="post" 
            novalidate 
            class="needs-validation">

        <div class="mb-3">
          <label for="rating" class="form-label">Rating</label>

          <fieldset class="starability-heartbeat">

            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked />
            <input type="radio" id="second-rate1" name="review[rating]" value="1" />
            <label for="second-rate1">1 star</label>

            <input type="radio" id="second-rate2" name="review[rating]" value="2" />
            <label for="second-rate2">2 stars</label>

            <input type="radio" id="second-rate3" name="review[rating]" value="3" />
            <label for="second-rate3">3 stars</label>

            <input type="radio" id="second-rate4" name="review[rating]" value="4" />
            <label for="second-rate4">4 stars</label>

            <input type="radio" id="second-rate5" name="review[rating]" value="5" />
            <label for="second-rate5">5 stars</label>

          </fieldset>
        </div>

        <div class="mb-3">
          <label for="comment" class="form-label">Comment</label>
          <textarea name="review[comment]" 
                    id="comment" 
                    rows="4" 
                    class="form-control" 
                    required></textarea>

          <div class="invalid-feedback">
            Please enter your comment.
          </div>
        </div>

        <button class="btn btn-primary">Submit</button>

      </form>

      <% } %>

    </div>
  </div>

  <hr class="my-4">

  <!-- Reviews Section -->
  <div class="row">
    <div class="col-md-8 mx-auto">

      <h4 class="mb-3">All Reviews</h4>

      <div class="row">

      <% for (review of listing.reviews) { %>

        <div class="col-md-6 mb-3">
          <div class="card">

            <div class="card-body">

              <h5 class="card-title">@ <%= review.author.username %></h5>

              <p class="card-text">
                <%= review.comment %>
              </p>

              <div class="starability-result" data-rating="<%= review.rating %>"></div>

              <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                    method="POST"
                    class="mt-2">

                <button class="btn btn-sm btn-dark">
                  Delete
                </button>

              </form>

            </div>

          </div>
        </div>

      <% } %>

      </div>

    </div>
  </div>

</div>